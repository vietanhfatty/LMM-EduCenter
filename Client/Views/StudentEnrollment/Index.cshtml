@model List<Client.Services.Models.EnrollmentDto>
@{
    ViewData["Title"] = "Đăng ký của tôi";
    int? status = ViewBag.Status as int?;
    string keyword = ViewBag.Keyword as string ?? "";
    int currentPage = ViewBag.Page ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int totalItems = ViewBag.TotalItems ?? 0;
    int pageSize = ViewBag.PageSize ?? 10;
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h1>Đăng ký của tôi</h1>
    <a asp-controller="StudentCourse" asp-action="Index" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-circle me-1"></i>Đăng ký khóa học mới
    </a>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label">Từ khóa</label>
                <input type="text" name="keyword" value="@keyword" class="form-control" placeholder="Lớp, khóa học, giáo viên..." />
            </div>
            <div class="col-md-3">
                <label class="form-label">Trạng thái</label>
                <select name="status" class="form-select">
                    <option value="">Tất cả</option>
                    <option value="0" selected="@(status == 0)">Chờ duyệt</option>
                    <option value="1" selected="@(status == 1)">Đã duyệt</option>
                    <option value="2" selected="@(status == 2)">Từ chối</option>
                    <option value="3" selected="@(status == 3)">Đã hủy</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Trang</label>
                <select name="pageSize" class="form-select">
                    <option value="5" selected="@(pageSize == 5)">5</option>
                    <option value="10" selected="@(pageSize == 10)">10</option>
                    <option value="20" selected="@(pageSize == 20)">20</option>
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search"></i></button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100"><i class="bi bi-arrow-clockwise"></i></a>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Bạn chưa có đăng ký nào. <a asp-controller="StudentCourse" asp-action="Index">Xem khóa học đang mở</a>.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Lớp học</th>
                    <th>Khóa học</th>
                    <th>Giáo viên</th>
                    <th>Lịch học</th>
                    <th>Ngày ĐK</th>
                    <th>Trạng thái</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @{ var idx = 0; }
                @foreach (var e in Model)
                {
                    idx++;
                    <tr>
                        <td>@(((currentPage - 1) * pageSize) + idx)</td>
                        <td>@e.ClassName</td>
                        <td>@e.CourseName</td>
                        <td>@e.TeacherName</td>
                        <td>
                            @foreach (var s in e.Schedules)
                            {
                                <span class="badge bg-light text-dark me-1">@s.DayOfWeekText @s.StartTime-@s.EndTime</span>
                            }
                        </td>
                        <td>@e.EnrollDate.ToString("dd/MM/yyyy")</td>
                        <td><span class="badge @e.StatusBadge">@e.StatusText</span></td>
                        <td>
                            @if (e.Status == 0)
                            {
                                <form asp-action="Cancel" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@e.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Bạn có chắc muốn hủy đăng ký này?')">
                                        <i class="bi bi-x-circle me-1"></i>Hủy
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="d-flex justify-content-between align-items-center mt-3">
    <div class="text-muted">Tổng: <strong>@totalItems</strong> đăng ký</div>
    <nav>
        <ul class="pagination pagination-sm mb-0">
            <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-keyword="@keyword" asp-route-status="@status" asp-route-pageSize="@pageSize" asp-route-page="@(currentPage - 1)">Trước</a>
            </li>
            <li class="page-item disabled"><span class="page-link">@currentPage / @totalPages</span></li>
            <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-keyword="@keyword" asp-route-status="@status" asp-route-pageSize="@pageSize" asp-route-page="@(currentPage + 1)">Sau</a>
            </li>
        </ul>
    </nav>
</div>
