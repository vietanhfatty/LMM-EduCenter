@{ ViewData["Title"] = "Báo cáo"; }

<div class="page-header"><h1>Báo cáo & Thống kê</h1></div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body text-center">
                <i class="bi bi-bar-chart text-primary" style="font-size:3rem;"></i>
                <h5 class="mt-2">Báo cáo doanh thu</h5>
                <p class="text-muted small">Xem doanh thu theo tháng/năm</p>
                <a asp-action="Revenue" class="btn btn-primary">Xem báo cáo</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body text-center">
                <i class="bi bi-check2-square text-success" style="font-size:3rem;"></i>
                <h5 class="mt-2">Báo cáo chuyên cần</h5>
                <p class="text-muted small">Xem tỷ lệ chuyên cần theo lớp</p>
                <a asp-action="Attendance" class="btn btn-success">Xem báo cáo</a>
            </div>
        </div>
    </div>
</div>
