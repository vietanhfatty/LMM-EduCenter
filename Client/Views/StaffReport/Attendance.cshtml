@model List<Client.Services.Models.AttendanceReportDto>
@{
    ViewData["Title"] = "Báo cáo chuyên cần";
    var classes = ViewBag.Classes as List<Client.Services.Models.ClassDto> ?? new();
    var selectedClassId = ViewBag.SelectedClassId as int?;
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h1>Báo cáo chuyên cần</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
</div>

<div class="mb-3">
    <form method="get" class="d-flex gap-2 align-items-end">
        <div>
            <label class="form-label">Chọn lớp</label>
            <select name="classId" class="form-select" onchange="this.form.submit()">
                <option value="">-- Chọn lớp --</option>
                @foreach (var c in classes)
                {
                    <option value="@c.Id" selected="@(selectedClassId == c.Id)">@c.Name — @c.CourseName</option>
                }
            </select>
        </div>
    </form>
</div>

@if (selectedClassId.HasValue && Model.Any())
{
    <div class="card">
        <div class="card-body table-responsive">
            <table class="table table-hover align-middle">
                <thead><tr><th>#</th><th>Học viên</th><th>Tổng buổi</th><th>Có mặt</th><th>Vắng</th><th>Muộn</th><th>Có phép</th><th>Tỷ lệ</th></tr></thead>
                <tbody>
                    @{ var i = 0; }
                    @foreach (var r in Model)
                    {
                        i++;
                        <tr>
                            <td>@i</td><td>@r.StudentName</td><td>@r.TotalSessions</td>
                            <td class="text-success">@r.Present</td><td class="text-danger">@r.Absent</td>
                            <td class="text-warning">@r.Late</td><td class="text-info">@r.Excused</td>
                            <td>
                                <div class="progress" style="min-width:80px;">
                                    <div class="progress-bar @(r.AttendanceRate >= 80 ? "bg-success" : r.AttendanceRate >= 50 ? "bg-warning" : "bg-danger")"
                                         style="width:@r.AttendanceRate%;">@r.AttendanceRate%</div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else if (selectedClassId.HasValue)
{
    <div class="alert alert-info">Chưa có dữ liệu điểm danh cho lớp này.</div>
}
