@model Client.Services.Models.RevenueReportDto
@{ ViewData["Title"] = "Báo cáo doanh thu"; }

<div class="page-header d-flex justify-content-between align-items-center">
    <h1>Báo cáo doanh thu</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
</div>

@if (Model != null)
{
    <div class="card mb-3">
        <div class="card-body text-center">
            <h4>Năm @Model.Year</h4>
            <div class="fs-3 fw-bold text-success">Tổng: @Model.TotalRevenue.ToString("N0") VND</div>
        </div>
    </div>
    <div class="card">
        <div class="card-body">
            <table class="table table-hover text-center">
                <thead><tr><th>Tháng</th><th>Doanh thu</th><th></th></tr></thead>
                <tbody>
                    @for (int m = 1; m <= 12; m++)
                    {
                        var data = Model.MonthlyData.FirstOrDefault(d => d.Month == m);
                        var total = data?.Total ?? 0;
                        var maxT = Model.MonthlyData.Any() ? Model.MonthlyData.Max(d => d.Total) : 1;
                        var pct = maxT > 0 ? (double)total / (double)maxT * 100 : 0;
                        <tr>
                            <td>Tháng @m</td><td class="fw-bold">@total.ToString("N0")</td>
                            <td><div class="progress"><div class="progress-bar bg-success" style="width:@pct%;">@(total > 0 ? total.ToString("N0") : "")</div></div></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
