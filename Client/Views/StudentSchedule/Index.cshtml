@model List<Client.Services.Models.EnrollmentDto>
@{
    ViewData["Title"] = "Lịch học";
    string keyword = ViewBag.Keyword as string ?? "";
    int currentPage = ViewBag.Page ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int totalItems = ViewBag.TotalItems ?? 0;
    int pageSize = ViewBag.PageSize ?? 10;
    var days = new[] { "Thứ 2", "Thứ 3", "Thứ 4", "Thứ 5", "Thứ 6", "Thứ 7", "Chủ nhật" };
    var dayMap = new Dictionary<int, string>
    {
        { 1, "Thứ 2" }, { 2, "Thứ 3" }, { 3, "Thứ 4" },
        { 4, "Thứ 5" }, { 5, "Thứ 6" }, { 6, "Thứ 7" }, { 0, "Chủ nhật" }
    };
    var colors = new[] { "primary", "success", "info", "warning", "danger", "secondary" };
}

<div class="page-header">
    <h1>Lịch học của tôi</h1>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-8">
                <label class="form-label">Từ khóa</label>
                <input type="text" name="keyword" value="@keyword" class="form-control" placeholder="Lớp, khóa học, giáo viên..." />
            </div>
            <div class="col-md-2">
                <label class="form-label">Trang</label>
                <select name="pageSize" class="form-select">
                    <option value="5" selected="@(pageSize == 5)">5</option>
                    <option value="10" selected="@(pageSize == 10)">10</option>
                    <option value="20" selected="@(pageSize == 20)">20</option>
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search"></i></button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100"><i class="bi bi-arrow-clockwise"></i></a>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Bạn chưa có lớp học nào. <a asp-controller="StudentCourse" asp-action="Index">Đăng ký khóa học</a>.
    </div>
}

<div class="d-flex justify-content-between align-items-center mt-3">
    <div class="text-muted">Tổng: <strong>@totalItems</strong> lớp đã duyệt</div>
    <nav>
        <ul class="pagination pagination-sm mb-0">
            <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-keyword="@keyword" asp-route-pageSize="@pageSize" asp-route-page="@(currentPage - 1)">Trước</a>
            </li>
            <li class="page-item disabled"><span class="page-link">@currentPage / @totalPages</span></li>
            <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-keyword="@keyword" asp-route-pageSize="@pageSize" asp-route-page="@(currentPage + 1)">Sau</a>
            </li>
        </ul>
    </nav>
</div>
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered text-center">
                    <thead class="table-dark">
                        <tr>
                            @foreach (var day in days)
                            {
                                <th style="width:14.28%;">@day</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            @{
                                var dayOrder = new[] { 1, 2, 3, 4, 5, 6, 0 };
                            }
                            @foreach (var d in dayOrder)
                            {
                                <td class="align-top" style="min-height:100px;">
                                    @{
                                        var colorIdx = 0;
                                    }
                                    @foreach (var enrollment in Model)
                                    {
                                        var schedules = enrollment.Schedules.Where(s => s.DayOfWeek == d);
                                        foreach (var s in schedules)
                                        {
                                            var c = colors[colorIdx % colors.Length];
                                            <div class="badge bg-@c d-block mb-1 p-2 text-start" style="white-space:normal;">
                                                <div class="fw-bold">@enrollment.ClassName</div>
                                                <div class="small">@s.StartTime - @s.EndTime</div>
                                                <div class="small">@enrollment.TeacherName</div>
                                            </div>
                                        }
                                        colorIdx++;
                                    }
                                </td>
                            }
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header fw-bold">Chi tiết lớp học</div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Lớp</th>
                            <th>Khóa học</th>
                            <th>Giáo viên</th>
                            <th>Lịch học</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in Model)
                        {
                            <tr>
                                <td>@e.ClassName</td>
                                <td>@e.CourseName</td>
                                <td>@e.TeacherName</td>
                                <td>
                                    @foreach (var s in e.Schedules)
                                    {
                                        <span class="badge bg-light text-dark me-1">@s.DayOfWeekText @s.StartTime-@s.EndTime</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

