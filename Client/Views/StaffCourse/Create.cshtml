@model Client.Services.Models.CreateCourseRequest
@{
    ViewData["Title"] = "Thêm khóa học";
}

<div class="page-header">
    <h1>Thêm khóa học mới</h1>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tên khóa học <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="VD: Lập trình C# cơ bản" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Mô tả nội dung khóa học..."></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Học phí (VND) <span class="text-danger">*</span></label>
                            <input asp-for="Fee" type="number" class="form-control" min="0" step="1000" />
                            <span asp-validation-for="Fee" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Thời lượng (giờ) <span class="text-danger">*</span></label>
                            <input asp-for="DurationInHours" type="number" class="form-control" min="1" />
                            <span asp-validation-for="DurationInHours" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label">Hoạt động</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Lưu
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
