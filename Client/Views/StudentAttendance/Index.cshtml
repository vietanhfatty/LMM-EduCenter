@model List<Client.Services.Models.AttendanceDto>
@{
    ViewData["Title"] = "Điểm danh của tôi";
    var classes = ViewBag.Classes as List<Client.Services.Models.EnrollmentDto> ?? new();
    var selectedClassId = ViewBag.SelectedClassId as int?;
    string keyword = ViewBag.Keyword as string ?? "";
    int currentPage = ViewBag.Page ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int totalItems = ViewBag.TotalItems ?? 0;
    int pageSize = ViewBag.PageSize ?? 10;
}

<div class="page-header"><h1>Điểm danh của tôi</h1></div>

<div class="mb-3">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label">Chọn lớp</label>
            <select name="classId" class="form-select" onchange="this.form.submit()">
                <option value="">-- Chọn lớp --</option>
                @foreach (var c in classes)
                {
                    <option value="@c.ClassId" selected="@(selectedClassId == c.ClassId)">@c.ClassName — @c.CourseName</option>
                }
            </select>
        </div>
        <div class="col-md-5">
            <label class="form-label">Từ khóa</label>
            <input type="text" name="keyword" value="@keyword" class="form-control" placeholder="Ngày, trạng thái, ghi chú..." />
        </div>
        <div class="col-md-1">
            <label class="form-label">Trang</label>
            <select name="pageSize" class="form-select">
                <option value="5" selected="@(pageSize == 5)">5</option>
                <option value="10" selected="@(pageSize == 10)">10</option>
                <option value="20" selected="@(pageSize == 20)">20</option>
            </select>
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search"></i></button>
            <a asp-action="Index" asp-route-classId="@selectedClassId" class="btn btn-outline-secondary w-100"><i class="bi bi-arrow-clockwise"></i></a>
        </div>
    </form>
</div>

@if (selectedClassId.HasValue)
{
    @if (!Model.Any())
    {
        <div class="alert alert-info">Chưa có dữ liệu điểm danh cho lớp này.</div>
    }
    else
    {
        var present = Model.Count(a => a.Status == 0);
        var absent = Model.Count(a => a.Status == 1);
        var late = Model.Count(a => a.Status == 2);
        var excused = Model.Count(a => a.Status == 3);
        var total = Model.Count;
        var rate = total > 0 ? Math.Round((present + late) * 100.0 / total, 1) : 0;

        <div class="row g-3 mb-3">
            <div class="col-auto"><span class="badge bg-success p-2">Có mặt: @present</span></div>
            <div class="col-auto"><span class="badge bg-danger p-2">Vắng: @absent</span></div>
            <div class="col-auto"><span class="badge bg-warning text-dark p-2">Muộn: @late</span></div>
            <div class="col-auto"><span class="badge bg-info p-2">Có phép: @excused</span></div>
            <div class="col-auto"><span class="badge bg-dark p-2">Tỷ lệ: @rate%</span></div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead><tr><th>#</th><th>Ngày</th><th>Trạng thái</th><th>Ghi chú</th></tr></thead>
                <tbody>
                    @{ var i = 0; }
                    @foreach (var a in Model)
                    {
                        i++;
                        <tr>
                            <td>@(((currentPage - 1) * pageSize) + i)</td>
                            <td>@a.Date.ToString("dd/MM/yyyy")</td>
                            <td><span class="badge @a.StatusBadge">@a.StatusText</span></td>
                            <td>@(a.Note ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-3">
            <div class="text-muted">Tổng: <strong>@totalItems</strong> buổi</div>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-classId="@selectedClassId" asp-route-keyword="@keyword" asp-route-pageSize="@pageSize" asp-route-page="@(currentPage - 1)">Trước</a>
                    </li>
                    <li class="page-item disabled"><span class="page-link">@currentPage / @totalPages</span></li>
                    <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-classId="@selectedClassId" asp-route-keyword="@keyword" asp-route-pageSize="@pageSize" asp-route-page="@(currentPage + 1)">Sau</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
}
