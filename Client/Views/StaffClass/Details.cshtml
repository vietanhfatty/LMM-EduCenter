@model Client.Services.Models.ClassDto
@{
    ViewData["Title"] = "Chi tiết lớp học";
}

<div class="page-header">
    <h1>Chi tiết lớp học</h1>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="bi bi-pencil me-1"></i>Sửa</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header fw-semibold">Thông tin lớp học</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Tên lớp</dt>
                    <dd class="col-sm-8 fw-semibold">@Model.Name</dd>

                    <dt class="col-sm-4">Khóa học</dt>
                    <dd class="col-sm-8">@Model.CourseName</dd>

                    <dt class="col-sm-4">Giáo viên</dt>
                    <dd class="col-sm-8">@Model.TeacherName</dd>

                    <dt class="col-sm-4">Phòng học</dt>
                    <dd class="col-sm-8">@Model.RoomName</dd>

                    <dt class="col-sm-4">Thời gian</dt>
                    <dd class="col-sm-8">@Model.StartDate.ToString("dd/MM/yyyy") - @Model.EndDate.ToString("dd/MM/yyyy")</dd>

                    <dt class="col-sm-4">Sĩ số</dt>
                    <dd class="col-sm-8">@Model.CurrentStudents / @Model.MaxStudents</dd>

                    <dt class="col-sm-4">Trạng thái</dt>
                    <dd class="col-sm-8"><span class="badge @Model.StatusBadge badge-status">@Model.StatusText</span></dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card">
            <div class="card-header fw-semibold">Lịch học</div>
            <div class="card-body">
                @if (Model.Schedules.Any())
                {
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr><th>Thứ</th><th>Giờ bắt đầu</th><th>Giờ kết thúc</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model.Schedules.OrderBy(s => s.DayOfWeek))
                            {
                                <tr>
                                    <td class="fw-semibold">@s.DayOfWeekText</td>
                                    <td>@s.StartTime</td>
                                    <td>@s.EndTime</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted mb-0">Chưa có lịch học.</p>
                }
            </div>
        </div>
    </div>
</div>
