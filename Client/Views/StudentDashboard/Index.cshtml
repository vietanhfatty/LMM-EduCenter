@{
    ViewData["Title"] = "Student Dashboard";
}

<div class="teacher-dashboard">
    <div class="teacher-kpi-grid">
        <div class="teacher-kpi-card">
            <div class="teacher-kpi-icon teacher-kpi-icon-blue">
                <i class="bi bi-calendar3"></i>
            </div>
            <div>
                <p class="teacher-kpi-label">Lớp đang học</p>
                <h3 class="teacher-kpi-value">—</h3>
            </div>
        </div>
        <div class="teacher-kpi-card">
            <div class="teacher-kpi-icon teacher-kpi-icon-mint">
                <i class="bi bi-journal-text"></i>
            </div>
            <div>
                <p class="teacher-kpi-label">Điểm trung bình</p>
                <h3 class="teacher-kpi-value">—</h3>
            </div>
        </div>
        <div class="teacher-kpi-card">
            <div class="teacher-kpi-icon teacher-kpi-icon-orange">
                <i class="bi bi-credit-card"></i>
            </div>
            <div>
                <p class="teacher-kpi-label">Học phí</p>
                <h3 class="teacher-kpi-value">—</h3>
            </div>
        </div>
        <div class="teacher-kpi-card">
            <div class="teacher-kpi-icon teacher-kpi-icon-blue">
                <i class="bi bi-bell"></i>
            </div>
            <div>
                <p class="teacher-kpi-label">Thông báo mới</p>
                <h3 class="teacher-kpi-value">—</h3>
            </div>
        </div>
    </div>

    <div class="teacher-card">
        <div class="teacher-card-header">
            <div>
                <h2>Lịch học hôm nay</h2>
                <p>Dữ liệu sẽ cập nhật khi có lớp được phân công.</p>
            </div>
        </div>
        <div class="p-5 text-center text-muted">
            <i class="bi bi-calendar-week" style="font-size: 3rem;"></i>
            <p class="mt-2 mb-0">Lịch học hôm nay sẽ được hiển thị khi có dữ liệu.</p>
        </div>
    </div>
</div>
