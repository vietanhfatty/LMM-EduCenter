@model Client.Services.Models.EnrollmentDto
@{
    ViewData["Title"] = "Chi tiết đăng ký";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h1>Chi tiết đăng ký #@Model.Id</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Quay lại
    </a>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body">
                <table class="table table-borderless">
                    <tr>
                        <th style="width:200px;">Học viên:</th>
                        <td>@Model.StudentName</td>
                    </tr>
                    <tr>
                        <th>Email:</th>
                        <td>@Model.StudentEmail</td>
                    </tr>
                    <tr>
                        <th>Lớp học:</th>
                        <td>@Model.ClassName</td>
                    </tr>
                    <tr>
                        <th>Khóa học:</th>
                        <td>@Model.CourseName</td>
                    </tr>
                    <tr>
                        <th>Giáo viên:</th>
                        <td>@Model.TeacherName</td>
                    </tr>
                    <tr>
                        <th>Sĩ số:</th>
                        <td>@Model.CurrentStudents / @Model.MaxStudents</td>
                    </tr>
                    <tr>
                        <th>Lịch học:</th>
                        <td>
                            @foreach (var s in Model.Schedules)
                            {
                                <span class="badge bg-light text-dark me-1">@s.DayOfWeekText @s.StartTime-@s.EndTime</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>Ngày đăng ký:</th>
                        <td>@Model.EnrollDate.ToString("dd/MM/yyyy HH:mm")</td>
                    </tr>
                    <tr>
                        <th>Trạng thái:</th>
                        <td><span class="badge @Model.StatusBadge">@Model.StatusText</span></td>
                    </tr>
                </table>

                @if (Model.Status == 0)
                {
                    <hr />
                    <div class="d-flex gap-2">
                        <form asp-action="Approve" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-success"
                                    onclick="return confirm('Duyệt đăng ký này?')">
                                <i class="bi bi-check-circle me-1"></i>Duyệt đăng ký
                            </button>
                        </form>
                        <form asp-action="Reject" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-danger"
                                    onclick="return confirm('Từ chối đăng ký này?')">
                                <i class="bi bi-x-circle me-1"></i>Từ chối
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
