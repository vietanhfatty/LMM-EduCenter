@model Client.Services.Models.NotificationDto
@{ ViewData["Title"] = Model.Title; }

<div class="page-header d-flex justify-content-between align-items-center">
    <h1>@Model.Title</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
</div>

<div class="card">
    <div class="card-body">
        <div class="mb-3 text-muted small">
            <i class="bi bi-person me-1"></i>@Model.SenderName |
            <i class="bi bi-clock me-1"></i>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
        </div>
        <div>@Model.Content</div>
    </div>
</div>
