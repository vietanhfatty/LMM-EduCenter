@model List<Client.Services.Models.DebtDto>
@{ ViewData["Title"] = "Công nợ học phí"; }

<div class="page-header d-flex justify-content-between align-items-center">
    <h1>Công nợ học phí</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-success">Không có công nợ nào.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead><tr><th>#</th><th>Học viên</th><th>Email</th><th>Lớp</th><th>Học phí</th><th>Đã đóng</th><th>Còn lại</th></tr></thead>
            <tbody>
                @{ var i = 0; }
                @foreach (var d in Model)
                {
                    i++;
                    <tr>
                        <td>@i</td><td>@d.StudentName</td><td>@d.StudentEmail</td><td>@d.ClassName</td>
                        <td>@d.CourseFee.ToString("N0")</td>
                        <td class="text-success">@d.TotalPaid.ToString("N0")</td>
                        <td class="fw-bold text-danger">@d.Remaining.ToString("N0") VND</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
