@model List<Client.Services.Models.PaymentDto>
@{
    ViewData["Title"] = "Học phí của tôi";
    var debts = ViewBag.Debts as List<Client.Services.Models.DebtDto> ?? new();
    string keyword = ViewBag.Keyword as string ?? "";
    int? method = ViewBag.Method as int?;
    int? status = ViewBag.Status as int?;
    int currentPage = ViewBag.Page ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int totalItems = ViewBag.TotalItems ?? 0;
    int pageSize = ViewBag.PageSize ?? 10;
}

<div class="page-header"><h1>Học phí của tôi</h1></div>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label">Từ khóa</label>
                <input type="text" name="keyword" value="@keyword" class="form-control" placeholder="Lớp, khóa học, ghi chú..." />
            </div>
            <div class="col-md-2">
                <label class="form-label">Phương thức</label>
                <select name="method" class="form-select">
                    <option value="">Tất cả</option>
                    <option value="0" selected="@(method == 0)">Tiền mặt</option>
                    <option value="1" selected="@(method == 1)">Chuyển khoản</option>
                    <option value="2" selected="@(method == 2)">Thẻ</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Trạng thái</label>
                <select name="status" class="form-select">
                    <option value="">Tất cả</option>
                    <option value="0" selected="@(status == 0)">Chờ xử lý</option>
                    <option value="1" selected="@(status == 1)">Đã thanh toán</option>
                    <option value="2" selected="@(status == 2)">Đã hoàn</option>
                </select>
            </div>
            <div class="col-md-1">
                <label class="form-label">Trang</label>
                <select name="pageSize" class="form-select">
                    <option value="5" selected="@(pageSize == 5)">5</option>
                    <option value="10" selected="@(pageSize == 10)">10</option>
                    <option value="20" selected="@(pageSize == 20)">20</option>
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search"></i></button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100"><i class="bi bi-arrow-clockwise"></i></a>
            </div>
        </form>
    </div>
</div>

@if (debts.Any())
{
    <div class="card mb-3 border-primary-subtle">
        <div class="card-header fw-bold text-primary"><i class="bi bi-bank me-1"></i>Tạo yêu cầu chuyển khoản</div>
        <div class="card-body">
            <form asp-action="CreateTransfer" method="post" class="row g-3">
                @Html.AntiForgeryToken()
                <div class="col-md-5">
                    <label class="form-label fw-bold">Lớp học</label>
                    <select name="ClassId" class="form-select" required>
                        <option value="">-- Chọn lớp còn công nợ --</option>
                        @foreach (var d in debts.Where(x => x.Remaining > 0))
                        {
                            <option value="@d.ClassId">@d.ClassName (Còn @d.Remaining.ToString("N0") VND)</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Số tiền chuyển khoản</label>
                    <input name="Amount" type="number" class="form-control" min="1000" step="1000" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">Ghi chú</label>
                    <input name="Note" class="form-control" placeholder="Mã giao dịch, nội dung CK..." />
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-send-check me-1"></i>Gửi yêu cầu xác nhận chuyển khoản
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header fw-bold text-danger"><i class="bi bi-exclamation-triangle me-1"></i>Công nợ</div>
        <div class="card-body">
            <table class="table table-sm align-middle">
                <thead><tr><th>Lớp</th><th>Học phí</th><th>Đã đóng</th><th>Còn lại</th></tr></thead>
                <tbody>
                    @foreach (var d in debts)
                    {
                        <tr>
                            <td>@d.ClassName</td>
                            <td>@d.CourseFee.ToString("N0")</td>
                            <td class="text-success">@d.TotalPaid.ToString("N0")</td>
                            <td class="fw-bold text-danger">@d.Remaining.ToString("N0") VND</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="card">
    <div class="card-header fw-bold">Lịch sử thanh toán</div>
    <div class="card-body">
        @if (!Model.Any())
        {
            <p class="text-muted">Chưa có thanh toán nào.</p>
        }
        else
        {
            <table class="table table-hover align-middle">
                <thead><tr><th>#</th><th>Lớp</th><th>Số tiền</th><th>Phương thức</th><th>Trạng thái</th><th>Ngày</th><th>Ghi chú</th></tr></thead>
                <tbody>
                    @{ var i = 0; }
                    @foreach (var p in Model)
                    {
                        i++;
                        <tr>
                            <td>@(((currentPage - 1) * pageSize) + i)</td><td>@p.ClassName</td>
                            <td class="fw-bold text-success">@p.Amount.ToString("N0") VND</td>
                            <td>@p.MethodText</td>
                            <td><span class="badge @p.StatusBadge">@p.StatusText</span></td>
                            <td>@p.PaymentDate.ToString("dd/MM/yyyy")</td>
                            <td>@(p.Note ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mt-3">
    <div class="text-muted">Tổng: <strong>@totalItems</strong> thanh toán</div>
    <nav>
        <ul class="pagination pagination-sm mb-0">
            <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-keyword="@keyword" asp-route-method="@method" asp-route-status="@status" asp-route-pageSize="@pageSize" asp-route-page="@(currentPage - 1)">Trước</a>
            </li>
            <li class="page-item disabled"><span class="page-link">@currentPage / @totalPages</span></li>
            <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-keyword="@keyword" asp-route-method="@method" asp-route-status="@status" asp-route-pageSize="@pageSize" asp-route-page="@(currentPage + 1)">Sau</a>
            </li>
        </ul>
    </nav>
</div>
