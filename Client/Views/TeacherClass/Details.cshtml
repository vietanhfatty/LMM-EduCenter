@model Client.Services.Models.ClassDto
@{ ViewData["Title"] = Model.Name; }

<div class="page-header d-flex justify-content-between align-items-center">
    <h1>@Model.Name</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header fw-bold">Thông tin lớp</div>
            <div class="card-body">
                <p><strong>Khóa học:</strong> @Model.CourseName</p>
                <p><strong>Phòng:</strong> @Model.RoomName</p>
                <p><strong>Sĩ số:</strong> @Model.CurrentStudents / @Model.MaxStudents</p>
                <p><strong>Thời gian:</strong> @Model.StartDate.ToString("dd/MM/yyyy") - @Model.EndDate.ToString("dd/MM/yyyy")</p>
                <p><strong>Trạng thái:</strong> <span class="badge @Model.StatusBadge">@Model.StatusText</span></p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header fw-bold">Lịch học</div>
            <div class="card-body">
                @foreach (var s in Model.Schedules)
                {
                    <span class="badge bg-light text-dark me-1 mb-1 p-2">@s.DayOfWeekText: @s.StartTime - @s.EndTime</span>
                }
            </div>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="TeacherAttendance" asp-action="Take" asp-route-id="@Model.Id" class="btn btn-success"><i class="bi bi-check2-square me-1"></i>Điểm danh</a>
            <a asp-controller="TeacherGrade" asp-action="Enter" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-journal-text me-1"></i>Nhập điểm</a>
        </div>
    </div>
</div>
