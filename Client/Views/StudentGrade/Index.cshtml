@model List<Client.Services.Models.StudentGradeSummaryDto>
@{
    ViewData["Title"] = "Điểm của tôi";
    string keyword = ViewBag.Keyword as string ?? "";
}

<div class="page-header"><h1>Điểm của tôi</h1></div>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-10">
                <label class="form-label">Từ khóa</label>
                <input type="text" name="keyword" value="@keyword" class="form-control" placeholder="Lớp hoặc khóa học..." />
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search"></i></button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100"><i class="bi bi-arrow-clockwise"></i></a>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Chưa có điểm nào.</div>
}
else
{
    @foreach (var summary in Model)
    {
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fw-bold">@summary.ClassName — @summary.CourseName</span>
                @if (summary.WeightedAverage.HasValue)
                {
                    <span class="badge @(summary.WeightedAverage >= 5 ? "bg-success" : "bg-danger") fs-6">
                        TB: @summary.WeightedAverage.Value.ToString("F2")
                    </span>
                }
            </div>
            <div class="card-body">
                @if (!summary.Grades.Any())
                {
                    <p class="text-muted">Chưa có điểm.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead><tr><th>Loại</th><th>Mô tả</th><th>Điểm</th><th>Trọng số</th></tr></thead>
                            <tbody>
                                @foreach (var g in summary.Grades)
                                {
                                    <tr>
                                        <td><span class="badge bg-light text-dark">@g.TypeText</span></td>
                                        <td>@(g.Description ?? "—")</td>
                                        <td class="fw-bold @(g.Score >= 5 ? "text-success" : "text-danger")">@g.Score.ToString("F1")</td>
                                        <td>@g.Weight</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
}
