@model List<Client.ViewModels.Teacher.TeacherAttendanceSessionViewModel>
@{
    ViewData["Title"] = "Điểm danh";
    var selectedDate = ViewBag.SelectedDate is DateTime dt ? dt : DateTime.Today;
}

<div class="page-header"><h1>Điểm danh</h1></div>
<p class="text-muted">Chọn ngày để xem lịch dạy và điểm danh. Trong cùng ngày bạn có thể mở lại để cập nhật điểm danh.</p>

<form asp-action="Index" method="get" class="row g-2 align-items-end mb-3">
    <div class="col-auto">
        <label class="form-label mb-1">Ngày điểm danh</label>
        <input type="date" name="date" class="form-control" value="@selectedDate.ToString("yyyy-MM-dd")" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary">
            <i class="bi bi-search me-1"></i>Xem lịch
        </button>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Không có lịch dạy vào ngày @selectedDate.ToString("dd/MM/yyyy").
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Thời gian</th>
                    <th>Lớp</th>
                    <th>Khóa học</th>
                    <th>Phòng</th>
                    <th>Sĩ số</th>
                    <th>Hiệu lực lớp</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var session in Model)
                {
                    <tr>
                        <td>@session.DayOfWeekText (@session.StartTime - @session.EndTime)</td>
                        <td>@session.ClassName</td>
                        <td>@session.CourseName</td>
                        <td>@session.RoomName</td>
                        <td>@session.CurrentStudents/@session.MaxStudents</td>
                        <td>
                            @if (session.IsInDateRange)
                            {
                                <span class="badge bg-success">Hợp lệ để điểm danh</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    Ngoài thời gian lớp (@session.ClassStartDate.ToString("dd/MM/yyyy") - @session.ClassEndDate.ToString("dd/MM/yyyy"))
                                </span>
                            }
                        </td>
                        <td>
                            @if (session.IsInDateRange)
                            {
                                <a asp-action="Take"
                                   asp-route-id="@session.ClassId"
                                   asp-route-date="@selectedDate.ToString("yyyy-MM-dd")"
                                   class="btn btn-sm btn-success">
                                    <i class="bi bi-check2-square me-1"></i>Điểm danh
                                </a>
                            }
                            else
                            {
                                <button type="button" class="btn btn-sm btn-outline-secondary" disabled>
                                    <i class="bi bi-ban me-1"></i>Chưa điểm danh được
                                </button>
                            }
                            <a asp-action="History" asp-route-id="@session.ClassId" class="btn btn-sm btn-outline-info">
                                <i class="bi bi-clock-history me-1"></i>Lịch sử
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
