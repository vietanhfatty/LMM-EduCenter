@model List<Client.Services.Models.AttendanceReportDto>
@{
    ViewData["Title"] = "Lịch sử điểm danh";
    var classInfo = ViewBag.ClassInfo as Client.Services.Models.ClassDto;
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h1>Báo cáo chuyên cần: @classInfo?.Name</h1>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Chưa có dữ liệu điểm danh.</div>
}
else
{
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead><tr><th>#</th><th>Học viên</th><th>Tổng buổi</th><th>Có mặt</th><th>Vắng</th><th>Muộn</th><th>Có phép</th><th>Tỷ lệ</th></tr></thead>
                    <tbody>
                        @{ var i = 0; }
                        @foreach (var r in Model)
                        {
                            i++;
                            <tr>
                                <td>@i</td><td>@r.StudentName</td><td>@r.TotalSessions</td>
                                <td class="text-success">@r.Present</td>
                                <td class="text-danger">@r.Absent</td>
                                <td class="text-warning">@r.Late</td>
                                <td class="text-info">@r.Excused</td>
                                <td>
                                    <div class="progress" style="min-width:80px;">
                                        <div class="progress-bar @(r.AttendanceRate >= 80 ? "bg-success" : r.AttendanceRate >= 50 ? "bg-warning" : "bg-danger")"
                                             style="width:@r.AttendanceRate%;">@r.AttendanceRate%</div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
