@model List<Client.Services.Models.UserDto>
@{
    ViewData["Title"] = "Quản lý Giáo viên";
    string keyword = ViewBag.Keyword as string ?? "";
    bool? isActive = ViewBag.IsActive as bool?;
    int currentPage = ViewBag.Page ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int totalItems = ViewBag.TotalItems ?? 0;
    int pageSize = ViewBag.PageSize ?? 10;
}

<div class="page-header">
    <h1>Quản lý Giáo viên</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Thêm giáo viên
    </a>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-6">
                <label class="form-label">Từ khóa</label>
                <input type="text" name="keyword" value="@keyword" class="form-control" placeholder="Tên, email, điện thoại..." />
            </div>
            <div class="col-md-2">
                <label class="form-label">Trạng thái</label>
                <select name="isActive" class="form-select">
                    <option value="">Tất cả</option>
                    <option value="true" selected="@(isActive == true)">Hoạt động</option>
                    <option value="false" selected="@(isActive == false)">Vô hiệu hóa</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Trang</label>
                <select name="pageSize" class="form-select">
                    <option value="5" selected="@(pageSize == 5)">5</option>
                    <option value="10" selected="@(pageSize == 10)">10</option>
                    <option value="20" selected="@(pageSize == 20)">20</option>
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search"></i></button>
                <a asp-action="Index" class="btn btn-outline-secondary w-100"><i class="bi bi-arrow-clockwise"></i></a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Họ tên</th>
                    <th>Email</th>
                    <th>Điện thoại</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">Chưa có giáo viên nào.</td></tr>
                }
                @foreach (var (item, i) in Model.Select((v, i) => (v, i)))
                {
                    <tr>
                        <td>@(((currentPage - 1) * pageSize) + i + 1)</td>
                        <td class="fw-semibold">@item.FullName</td>
                        <td>@item.Email</td>
                        <td>@(item.Phone ?? "—")</td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success badge-status">Hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-danger badge-status">Vô hiệu hóa</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Chi tiết">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="Sửa">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="Toggle" asp-route-id="@item.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm @(item.IsActive ? "btn-outline-danger" : "btn-outline-success")" title="@(item.IsActive ? "Vô hiệu hóa" : "Kích hoạt")">
                                    <i class="bi @(item.IsActive ? "bi-lock" : "bi-unlock")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mt-3">
    <div class="text-muted">Tổng: <strong>@totalItems</strong> giáo viên</div>
    <nav>
        <ul class="pagination pagination-sm mb-0">
            <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-keyword="@keyword" asp-route-isActive="@isActive" asp-route-pageSize="@pageSize" asp-route-page="@(currentPage - 1)">Trước</a>
            </li>
            <li class="page-item disabled"><span class="page-link">@currentPage / @totalPages</span></li>
            <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-keyword="@keyword" asp-route-isActive="@isActive" asp-route-pageSize="@pageSize" asp-route-page="@(currentPage + 1)">Sau</a>
            </li>
        </ul>
    </nav>
</div>
